include /etc/sway/config.d/*

font pango:monospace 12

default_border          pixel 1
default_floating_border pixel 1

focus_wrapping      workspace
focus_follows_mouse no

set $mod  Mod4
set $next o
set $prev Shift+o

floating_modifier $mod normal

bindsym $mod+7      exec wmenu-run
bindsym $mod+Return exec alacritty

bindsym $mod+$next focus next
bindsym $mod+$prev focus prev

bindsym $mod+k kill

bindsym $mod+Shift+e reload
bindsym $mod+Shift+k exit

bindsym $mod+a workspace a
bindsym $mod+s workspace s
bindsym $mod+d workspace d
bindsym $mod+f workspace f

bindsym $mod+Shift+a move container to workspace a
bindsym $mod+Shift+s move container to workspace s
bindsym $mod+Shift+d move container to workspace d
bindsym $mod+Shift+f move container to workspace f

bindsym $mod+2 splitv
bindsym $mod+3 splith

bindsym $mod+l       layout tabbed
bindsym $mod+Shift+l layout toggle split

bindsym $mod+space       floating toggle
bindsym $mod+Shift+space focus mode_toggle

bar {
    position bottom
    status_command while date +'%Y-%m-%d %X'; do sleep 1; done

    colors {
        statusline #ffffff
        background #323232
        inactive_workspace #32323200 #32323200 #5c5c5c
    }
}
